# Application
NODE_ENV=development
APP_ENV=development
LOG_LEVEL=info

# Ports and URLs
WEB_PORT=3100
API_PORT=3101
WEB_URL=http://localhost:3100
API_URL=http://localhost:3101
NEXT_PUBLIC_API_URL=http://localhost:3101
# Optional public MCP URL when clients reach the API via a different host (proxy / split DNS).
# Example: https://knowledge.example.com/mcp
# MCP_PUBLIC_URL=

# PostgreSQL (local development — change credentials in real deployments)
DATABASE_URL=postgres://knowledge_hub:knowledge_hub@127.0.0.1:5432/knowledge_hub

# Redis (local development)
REDIS_URL=redis://127.0.0.1:6379

# Git sync safety sweep (worker): re-enqueue all active connections on this interval.
# Default 86400000 (24h). Set 0 to disable.
# GIT_SYNC_SAFETY_INTERVAL_MS=86400000

# Sessions (generate a unique secret for each environment; min 32 characters)
SESSION_SECRET=dev-only-change-me-to-a-long-random-secret
SESSION_COOKIE_NAME=kh_session
SESSION_TTL_SECONDS=86400

# Bootstrap administrator (used by `pnpm db:seed` only)
BOOTSTRAP_ADMIN_EMAIL=admin@localhost.local
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-pass
BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrator

# Default organization seed
DEFAULT_ORGANIZATION_NAME="Default Organization"
DEFAULT_ORGANIZATION_SLUG=default

# Outbound mail (invite + password reset). Drivers: console | smtp | resend
# Prefer Admin → Email in the UI for runtime overrides; these are env defaults/fallback.
MAIL_DRIVER=console
MAIL_FROM="Project Knowledge Hub <noreply@localhost.local>"
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# RESEND_API_KEY=
# AUTH_PASSWORD_RESET_TTL_SECONDS=3600
# AUTH_INVITE_TTL_SECONDS=604800
# AUTH_EMAIL_CONFIRM_TTL_SECONDS=86400

# Profile avatars (local disk; one file per user id under this directory)
# AVATAR_UPLOAD_DIR=./data/avatars
# AVATAR_MAX_BYTES=1048576

# Workspace knowledge media (JPEG/PNG/WebP; local fallback when BLOB_PROVIDER=disabled)
# MEDIA_UPLOAD_DIR=./data/media
# MEDIA_MAX_BYTES=5242880

# Signup pending escalation (worker emails all system admins once after age)
# SIGNUP_PENDING_ESCALATE_AFTER_HOURS=4
# SIGNUP_PENDING_ESCALATE_INTERVAL_MS=900000

# Ops-0 DB backups (scripts + optional: docker compose --profile backup up -d db-backup)
# Shared with API for Admin → Monitoring export/import (NF-011).
# BACKUP_DIR=./backups
# BACKUP_MAX_UPLOAD_BYTES=536870912
# BACKUP_KEEP_DAILY=7
# BACKUP_KEEP_WEEKLY=4
# BACKUP_KEEP_MONTHLY=3
# BACKUP_AUTO_ROTATE=true
# BACKUP_OFFSITE=true
# BACKUP_OFFSITE_SYNC_INTERVAL_MS=300000
#
# BlobStore (NF-006) — S3-compatible offsite dumps (AWS S3, R2, B2, MinIO, …)
# BLOB_PROVIDER=disabled
# BLOB_PROVIDER=s3
# BLOB_S3_BUCKET=knowledge-hub
# BLOB_S3_REGION=auto
# BLOB_S3_ENDPOINT=https://s3.example.com
# BLOB_S3_ACCESS_KEY_ID=
# BLOB_S3_SECRET_ACCESS_KEY=
# BLOB_S3_FORCE_PATH_STYLE=true
# BLOB_KEY_PREFIX=staging
# BACKUP_ENABLED=true
# BACKUP_INTERVAL_SECONDS=86400
# Admin → Monitoring can override via BACKUP_DIR/schedule.json (no sidecar restart).

# Milestone 10 — semantic / hybrid search (optional; default FTS-only)
# EMBEDDING_PROVIDER=disabled|ollama|openai_compatible
EMBEDDING_PROVIDER=disabled
EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_BASE_URL=http://127.0.0.1:11434
# EMBEDDING_API_KEY=
# Must match pgvector column vector(768) and the active model output size
EMBEDDING_DIMENSIONS=768
# Allow clients to request mode=hybrid when a live provider is configured
SEARCH_HYBRID_ENABLED=false
