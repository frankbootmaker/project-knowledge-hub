# Example env for compose.dokploy.yaml (Dev/UAT). Copy to a Dokploy secret store — do not commit real values.
# Only set optional vars when you have real values (empty SMTP_* / MCP_PUBLIC_URL break Zod).

APP_ENV=staging
NODE_ENV=production
LOG_LEVEL=info

# Public HTTPS origin (Dokploy domain). Used for cookies, mail links, AI discover.
WEB_URL=https://knowledge-hub.example.com

# Optional. When unset, public MCP defaults to {WEB_URL}/mcp (same-origin rewrite).
# Only set if clients must use a different public host than WEB_URL.
# MCP_PUBLIC_URL=https://knowledge-hub.example.com/mcp

# Do NOT set API_URL=http://localhost:3101 here — that poisons the web image
# (Next would proxy to itself). Compose hardcodes http://api:3101 for Dokploy.

# Postgres (service hostname `postgres`). Compose builds DATABASE_URL from these —
# do not rely on a laptop DATABASE_URL pointing at 127.0.0.1.
POSTGRES_DB=knowledge_hub
POSTGRES_USER=knowledge_hub
POSTGRES_PASSWORD=change-me-strong-password

# Auth (min 32 characters)
SESSION_SECRET=change-me-to-a-long-random-string-min-32

# Optional first-boot seed (run infrastructure/scripts/seed.sh once)
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-pass
DEFAULT_ORGANIZATION_NAME=Default Organization
DEFAULT_ORGANIZATION_SLUG=default

# Ops-0 DB backup sidecar (compose service db-backup → volume knowledge_hub_backups)
# API also mounts the same volume at BACKUP_DIR for Admin → Monitoring.
# BACKUP_DIR=/backups
# BACKUP_MAX_UPLOAD_BYTES=536870912
# BACKUP_ENABLED=true
# BACKUP_INTERVAL_SECONDS=86400
# BACKUP_KEEP_DAILY=7
# BACKUP_KEEP_WEEKLY=4
# BACKUP_KEEP_MONTHLY=3
# BACKUP_AUTO_ROTATE=true
# BACKUP_OFFSITE=true
# BACKUP_OFFSITE_SYNC_INTERVAL_MS=300000
# BACKUP_RUN_ON_START=1
#
# BlobStore offsite (S3-compatible: AWS / R2 / B2 / MinIO / …)
# Prefer Admin → Storage in the UI after deploy; env remains the fallback.
# BLOB_PROVIDER=disabled
# BLOB_PROVIDER=s3
# BLOB_S3_BUCKET=knowledge-hub
# BLOB_S3_REGION=auto
# BLOB_S3_ENDPOINT=
# BLOB_S3_ACCESS_KEY_ID=
# BLOB_S3_SECRET_ACCESS_KEY=
# BLOB_S3_FORCE_PATH_STYLE=false
# BLOB_KEY_PREFIX=

# Embeddings (default: FTS only)
EMBEDDING_PROVIDER=disabled
SEARCH_HYBRID_ENABLED=false

# Mail (console | smtp | resend). For smtp/resend, set the matching vars in Dokploy only.
MAIL_DRIVER=console
# MAIL_FROM=Project Knowledge Hub <noreply@example.com>
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# RESEND_API_KEY=
