# Example env for compose.dokploy.yaml (Dev/UAT). Copy to a Dokploy secret store — do not commit real values.
# Only set optional vars when you have real values (empty SMTP_* / MCP_PUBLIC_URL break Zod).

APP_ENV=staging
NODE_ENV=production
LOG_LEVEL=info

# Public HTTPS origin (Dokploy domain). Used for cookies, mail links, AI discover.
WEB_URL=https://knowledge-hub.example.com

# Optional public MCP URL (same-origin via web rewrite is recommended).
# MCP_PUBLIC_URL=https://knowledge-hub.example.com/mcp

# Internal API hostname for the web image build arg. Rebuild web if renamed.
INTERNAL_API_URL=http://api:3101

# Postgres (service hostname `postgres`). Compose builds DATABASE_URL from these —
# do not rely on a laptop DATABASE_URL pointing at 127.0.0.1.
POSTGRES_DB=knowledge_hub
POSTGRES_USER=knowledge_hub
POSTGRES_PASSWORD=change-me-strong-password

# Auth (min 32 characters)
SESSION_SECRET=change-me-to-a-long-random-string-min-32

# Optional first-boot seed (run infrastructure/scripts/seed.sh once)
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-pass
DEFAULT_ORGANIZATION_NAME=Default Organization
DEFAULT_ORGANIZATION_SLUG=default

# Embeddings (default: FTS only)
EMBEDDING_PROVIDER=disabled
SEARCH_HYBRID_ENABLED=false

# Mail (console | smtp | resend). For smtp/resend, set the matching vars in Dokploy only.
MAIL_DRIVER=console
# MAIL_FROM=Project Knowledge Hub <noreply@example.com>
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# RESEND_API_KEY=
