{
  "$schema": "https://turbo.build/schema.json",
  "concurrency": "25",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URL", "REDIS_URL", "APP_ENV", "NODE_ENV", "LOG_LEVEL", "API_PORT", "WEB_PORT", "API_URL", "WEB_URL"]
    }
  }
}
